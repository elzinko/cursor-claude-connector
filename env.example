# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Secret key to protect your proxy from unauthorized use.
# Set the same value in Cursor: Settings → Models → OpenAI API Key
API_KEY=your-secret-key-here

# ── REQUIRED on Vercel (auto-injected by Upstash integration) ─────────────────
# Add Upstash Redis via Vercel Dashboard → Storage → Connect Store → Upstash
# Credentials are injected automatically. Only set these manually if not using
# the Vercel Marketplace integration.
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx

# ── LOCAL / VPS ONLY ──────────────────────────────────────────────────────────
# These settings only matter when running the proxy outside of Vercel.
# On Vercel, they are ignored or auto-configured.

# Server port (default: 9095)
# PORT=9095

# Force storage mode: "file" (local) or "redis" (requires UPSTASH_* above)
# Default: auto-detect (redis if UPSTASH_* are set, file otherwise)
# STORAGE_MODE=file

# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# Allowed CORS origins (comma-separated). Defaults to permissive if unset.
# Recommended on Vercel: set to your Vercel URL
# CORS_ORIGINS=https://your-app.vercel.app

# Rate limiting (per API key)
# RATE_LIMIT_REQUESTS=100       # max requests per window (default: 100)
# RATE_LIMIT_WINDOW_MS=3600000  # window size in ms (default: 3600000 = 1h)

# Enable Anthropic's 1M context window beta for Sonnet models.
# Default: disabled — enabling this requires "long context" billing enabled
# on your Anthropic account, otherwise every Sonnet request fails with
# "Extra usage is required for long context requests."
# ENABLE_1M_CONTEXT=true

# Client-tracker retention (days of daily stats kept in Redis / memory)
# STATS_RETENTION_DAYS=30

# Anthropic OAuth Client ID
# Only change this if you know what you're doing. Defaults to the official Claude CLI ID.
# ANTHROPIC_OAUTH_CLIENT_ID=9d1c250a-e61b-44d9-88ed-5944d1962f5e
