# Storage: leave empty for local. Use npm run start:local or start:vercel
# Vercel: add Upstash Redis via Marketplace (Storage → Connect Store) - free tier
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx
# Optional: force mode (file|redis). Default: auto-detect
# STORAGE_MODE=file

API_KEY=custom-key

# Optional: Anthropic OAuth Client ID 
# Defaults to the official Claude CLI ID if not provided
# ANTHROPIC_OAUTH_CLIENT_ID=9d1c250a-e61b-44d9-88ed-5944d1962f5e

# Optional: Server port 
# Defaults to 9095 if not provided
# PORT=9095

# Optional: CORS allowed origins (comma-separated)
# Default: localhost + same-origin. Set to * for permissive (not recommended when public)
# CORS_ORIGINS=https://your-app.vercel.app