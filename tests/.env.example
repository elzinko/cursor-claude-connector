# Configuration du script tests/integration-tests.sh.
#
# Usage local  : copier ce fichier vers tests/.env et renseigner les valeurs.
#                Le fichier est gitignored (cf. .gitignore → tests/.env).
# Usage CI     : pas de .env — le workflow .github/workflows/pr-tests.yml
#                exporte les mêmes variables via les secrets GitHub
#                (API_KEY, VERCEL_BYPASS_TOKEN) et injecte BASE_URL à partir
#                de l'URL de preview Vercel.

# Clé API du proxy (même valeur que l'env var API_KEY déployée sur Vercel).
API_KEY=

# Optionnel — URL de base du proxy (doit finir par /v1).
# Par défaut : la prod (voir docs/USER_GUIDE.md).
#   Prod    : https://elzinko-cursor-claude-connector.vercel.app/v1
#   Preview : https://<deployment-id>.vercel.app/v1
# BASE_URL=https://elzinko-cursor-claude-connector.vercel.app/v1

# Optionnel — Vercel Deployment Protection bypass token.
# Requis uniquement pour tester une preview protégée par SSO.
# Docs : https://vercel.com/docs/deployment-protection/methods-to-bypass-deployment-protection/protection-bypass-automation
# VERCEL_BYPASS_TOKEN=
