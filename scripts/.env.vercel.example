# Source of truth for Vercel env-var provisioning.
#
# Copy this file to scripts/.env.vercel (gitignored), fill in real values,
# then run `npm run provision:vercel`.
#
# Which envs each var targets is declared in scripts/provision-vercel-env.sh
# (ENV_MAP). Adding a new secret: add a line here + a line to ENV_MAP.

# Proxy auth key — same value you send as `Authorization: Bearer <...>`.
# Cursor / OpenClaw / tests all use this. Comma-separated list allowed if
# you want to support multiple tokens at once.
API_KEY=

# Vercel Protection Bypass token.
# Vercel dashboard → Project → Settings → Deployment Protection →
# "Protection Bypass for Automation" → copy token.
# Needed by CI to bypass the SSO gate on preview deployments.
VERCEL_BYPASS_TOKEN=

# Upstash Redis (rate-limit store). Get from upstash.com console.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
